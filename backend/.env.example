PORT=3000
NODE_ENV=development

# Railway Postgres — copy from Railway dashboard
DATABASE_URL=postgresql://user:password@host:port/database
DB_SSL=true

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Twilio Verify — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# S3-compatible storage (AWS S3 or Cloudflare R2)
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your_key_id
AWS_SECRET_ACCESS_KEY=your_secret
S3_BUCKET_PHOTOS=tarteb-candidate-photos
S3_BUCKET_CVS=tarteb-candidate-cvs
S3_BUCKET_LOGOS=tarteb-employer-logos
# For Cloudflare R2 only — leave blank for AWS S3
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# CORS — comma-separated allowed origins (leave blank to allow all in dev)
CORS_ORIGINS=

# Skip OTP verification in dev/testing (set to "true" to bypass Twilio)
SKIP_OTP_VERIFICATION=false
